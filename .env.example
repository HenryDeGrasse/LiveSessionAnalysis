# ──────────────────────────────────────────────────────────────
# LiveSessionAnalysis — Environment Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is gitignored and loaded automatically by docker-compose.
# ──────────────────────────────────────────────────────────────

# ── Auth Secrets ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
LSA_JWT_SECRET=
AUTH_SECRET=

# ── Google OAuth (optional — leave blank to disable) ─────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LiveKit ──────────────────────────────────────────────────
# Local dev: devkey/secret (matches livekit-server --dev defaults).
# Production: use your LiveKit Cloud or self-hosted keys.
LSA_LIVEKIT_API_KEY=devkey
LSA_LIVEKIT_API_SECRET=secret

# ── Sentry Observability (optional — leave blank to disable) ──
# Backend DSN — from your Sentry project settings (Python/FastAPI project)
LSA_SENTRY_DSN=
LSA_SENTRY_ENVIRONMENT=development

# Frontend DSN — from your Sentry project settings (Next.js project)
# NEXT_PUBLIC_ prefix exposes the value to the browser bundle.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Server-only DSN (falls back to NEXT_PUBLIC_SENTRY_DSN when absent)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── AI Conversational Intelligence (all features disabled by default) ──

# --- Transcription ---
# Master switch to enable real-time speech-to-text transcription.
# Requires a valid API key for the chosen provider.
LSA_ENABLE_TRANSCRIPTION=false

# STT provider: "assemblyai" (default) | "deepgram" | "mock"
LSA_TRANSCRIPTION_PROVIDER=assemblyai

# Roles to transcribe (JSON list). Student-only recommended for pilot.
LSA_TRANSCRIPTION_ROLES=["student"]

# Language code for transcription (BCP-47).
LSA_TRANSCRIPTION_LANGUAGE=en

# AssemblyAI API key (default provider)
# Get one at https://www.assemblyai.com/
LSA_ASSEMBLYAI_API_KEY=

# Deepgram API key (alternative provider — set LSA_TRANSCRIPTION_PROVIDER=deepgram)
# Get one at https://console.deepgram.com/
LSA_DEEPGRAM_API_KEY=

# Deepgram-specific settings (ignored when using AssemblyAI)
LSA_TRANSCRIPTION_MODEL=nova-2
LSA_DEEPGRAM_ENDPOINTING_MS=800
LSA_DEEPGRAM_MIP_OPT_OUT=true
LSA_TRANSCRIPTION_ENABLE_SENTIMENT=false

# Rolling transcript buffer window (seconds) for AI coaching context.
LSA_TRANSCRIPTION_BUFFER_WINDOW_SECONDS=120

# Max queued audio chunks before backpressure starts dropping.
LSA_TRANSCRIPTION_QUEUE_MAX_SIZE=200

# Provider keepalive heartbeat interval in seconds.
LSA_TRANSCRIPTION_KEEPALIVE_INTERVAL_SECONDS=8

# --- Uncertainty Detection ---
# Enable tone/uncertainty detection on transcribed audio.
# Requires LSA_ENABLE_TRANSCRIPTION=true.
LSA_ENABLE_UNCERTAINTY_DETECTION=false

# Confidence threshold above which uncertainty is surfaced in the UI.
LSA_UNCERTAINTY_UI_THRESHOLD=0.6

# Must sustain uncertainty across N utterances before surfacing.
LSA_UNCERTAINTY_PERSISTENCE_UTTERANCES=2

# Time window in seconds for persistence smoothing.
LSA_UNCERTAINTY_PERSISTENCE_WINDOW_SECONDS=45

# --- AI Coaching Copilot ---
# Enable AI-powered coaching suggestions during live sessions.
# Requires LSA_ENABLE_TRANSCRIPTION=true and a valid LLM API key.
LSA_ENABLE_AI_COACHING=false

# LLM provider: "openrouter" (default, recommended) | "anthropic"
# OpenRouter gives access to Claude, GPT-4o, Gemini, Llama via one key.
LSA_AI_COACHING_PROVIDER=openrouter

# Model name (OpenRouter format: "provider/model").
LSA_AI_COACHING_MODEL=anthropic/claude-3.5-haiku

# OpenRouter API key (default LLM provider)
# Get one at https://openrouter.ai/
LSA_OPENROUTER_API_KEY=

# Anthropic API key (alternative — set LSA_AI_COACHING_PROVIDER=anthropic)
# Get one at https://console.anthropic.com/
LSA_ANTHROPIC_API_KEY=

# Baseline interval (seconds) between proactive copilot evaluations.
LSA_AI_COACHING_BASELINE_INTERVAL_SECONDS=45

# Faster follow-up interval (seconds) during detected uncertainty bursts.
LSA_AI_COACHING_BURST_INTERVAL_SECONDS=15

# Maximum LLM calls per hour per session (cost guard).
LSA_AI_COACHING_MAX_CALLS_PER_HOUR=60

# --- Post-Session Enrichment ---
# Persist transcripts to storage after session ends.
LSA_ENABLE_TRANSCRIPT_STORAGE=false

# Generate an AI summary after session ends (requires transcript storage
# and a valid LLM API key).
LSA_ENABLE_AI_SESSION_SUMMARY=false
