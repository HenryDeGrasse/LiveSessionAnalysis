# ══════════════════════════════════════════════════════════════════════════════
# LiveSessionAnalysis — Production Environment Template
# ══════════════════════════════════════════════════════════════════════════════
#
# USAGE
#   This file documents every environment variable needed for a production
#   deployment.  It is safe to commit.  Never commit a file that contains
#   actual secret values.
#
#   For local development use .env.example (lighter, localhost defaults).
#   For production use Fly.io secrets, Doppler, or another secrets manager —
#   not a plain .env file on the server.
#
# GENERATION CHEATSHEET
#   Strong random secret:   openssl rand -base64 32
#   URL-safe random secret: openssl rand -hex 40
#
# SECTIONS
#   1.  Auth Secrets
#   2.  Google OAuth
#   3.  Database (Postgres)
#   4.  Object Storage (Cloudflare R2 / S3-compatible)
#   5.  LiveKit Cloud
#   6.  Observability (Sentry)
#   7.  Frontend URLs
#   8.  CORS
# ══════════════════════════════════════════════════════════════════════════════


# ── 1. Auth Secrets ───────────────────────────────────────────────────────────
# Backend JWT signing key.  Used by the FastAPI backend only.
# Generate: openssl rand -base64 32
LSA_JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# NextAuth.js session encryption key.  Used by the Next.js frontend only.
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# (Optional) Token expiry in hours.  Default: 24.
# LSA_JWT_EXPIRY_HOURS=24


# ── 2. Google OAuth ────────────────────────────────────────────────────────────
# Required only if you want Google sign-in.  Leave blank to disable it.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (production):
#   https://<your-frontend-domain>/api/auth/callback/google

# Backend: validates the OAuth client ID in Google-signed ID tokens.
LSA_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID

# Frontend (Next.js server-side NextAuth callbacks):
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET

# Frontend (browser bundle — triggers the Google One Tap / sign-in button).
# Build-time variable for Next.js client bundles.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID


# ── 3. Database (Postgres) ────────────────────────────────────────────────────
# Standard libpq-compatible connection string.
# Examples:
#   Neon:      postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/lsa?sslmode=require
#   Supabase:  postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require
#   Fly:       postgresql://user:password@lsa-db.flycast:5432/lsa
#
# SSL is required for all managed Postgres providers.
LSA_DATABASE_URL=postgresql://user:password@host:5432/lsa?sslmode=require

# Switch the session-summary and user-auth stores from local file/SQLite to
# Postgres.  Must be set to "postgres" alongside a valid LSA_DATABASE_URL.
# Values: "local" (default — file/SQLite) | "postgres"
LSA_STORAGE_BACKEND=postgres


# ── 4. Object Storage (Cloudflare R2 / S3-compatible) ─────────────────────────
# Switch trace storage from local disk to an S3-compatible bucket.
# Values: "local" (default — write to disk) | "s3"
LSA_TRACE_STORAGE_BACKEND=s3

# Cloudflare R2 endpoint:
#   https://<account-id>.r2.cloudflarestorage.com
# AWS S3 endpoint (optional — omit to use the default AWS regional endpoint):
#   https://s3.<region>.amazonaws.com
LSA_S3_ENDPOINT_URL=https://REPLACE_WITH_ACCOUNT_ID.r2.cloudflarestorage.com

# Bucket name.  Must already exist before first deploy.
LSA_S3_BUCKET_NAME=lsa-traces

# R2 / IAM access credentials.
# For Cloudflare R2: create an API token with "Object Read & Write" permission
# at https://dash.cloudflare.com/?to=/:account/r2/api-tokens
LSA_S3_ACCESS_KEY_ID=REPLACE_WITH_ACCESS_KEY_ID
LSA_S3_SECRET_ACCESS_KEY=REPLACE_WITH_SECRET_ACCESS_KEY

# (Optional) Key prefix for all trace objects.  Default: "traces/"
# LSA_S3_TRACE_PREFIX=traces/


# ── 5. LiveKit Cloud ──────────────────────────────────────────────────────────
# Create a project at https://cloud.livekit.io and copy the credentials from
# Settings → Keys.  See docs/livekit-cloud-setup.md for the full manual steps.

# Backend: used to sign room tokens and verify webhooks.
LSA_LIVEKIT_URL=wss://REPLACE_WITH_PROJECT.livekit.cloud
LSA_LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_API_KEY
LSA_LIVEKIT_API_SECRET=REPLACE_WITH_LIVEKIT_API_SECRET

# Frontend: embedded at build time; must match LSA_LIVEKIT_URL.
# For Fly.io this is injected as a Docker build arg — see docs/production-deployment-guide.md.
NEXT_PUBLIC_LIVEKIT_URL=wss://REPLACE_WITH_PROJECT.livekit.cloud


# ── 6. Observability (Sentry) ─────────────────────────────────────────────────
# Create projects at https://sentry.io — one for the backend (Python/FastAPI)
# and one for the frontend (Next.js).  Leave blank to disable Sentry.

# Backend DSN (Python SDK).
LSA_SENTRY_DSN=https://REPLACE_WITH_KEY@oXXXXXX.ingest.sentry.io/REPLACE_WITH_PROJECT_ID
LSA_SENTRY_ENVIRONMENT=production

# Frontend DSN (browser + server-side Next.js SDK).
# NEXT_PUBLIC_* values are build-time variables for Next.js client bundles.
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_WITH_KEY@oXXXXXX.ingest.sentry.io/REPLACE_WITH_PROJECT_ID
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Server-only frontend DSN alias (falls back to NEXT_PUBLIC_SENTRY_DSN when absent).
SENTRY_DSN=https://REPLACE_WITH_KEY@oXXXXXX.ingest.sentry.io/REPLACE_WITH_PROJECT_ID
SENTRY_ENVIRONMENT=production


# ── 7. Frontend URLs ──────────────────────────────────────────────────────────
# Public URL of the frontend.  Required for NextAuth OAuth redirect URIs.
NEXTAUTH_URL=https://lsa-frontend.fly.dev

# Server-to-server backend URL used inside NextAuth callbacks.
# In Docker / Fly.io with private networking, use the internal .flycast address.
NEXTAUTH_BACKEND_URL=http://lsa-backend.flycast:8000

# Public API base URL exposed to the browser (no trailing slash).
# Build-time variable for Next.js client bundles.
NEXT_PUBLIC_API_URL=https://lsa-backend.fly.dev

# Public WebSocket base URL exposed to the browser (no trailing slash).
# Build-time variable for Next.js client bundles.
NEXT_PUBLIC_WS_URL=wss://lsa-backend.fly.dev


# ── 8. CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list (or JSON array) of origins the backend allows.
# Must include the production frontend URL and any staging/preview URLs.
# Example: https://lsa-frontend.fly.dev,https://staging.example.com
LSA_CORS_ORIGINS=https://lsa-frontend.fly.dev
