FROM node:20-alpine AS builder

WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

# Build-time public env vars — Next.js inlines NEXT_PUBLIC_* at build time,
# so they must be present during `npm run build`, not only at runtime.
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_LIVEKIT_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_SENTRY_DSN
ARG NEXT_PUBLIC_SENTRY_ENVIRONMENT
ARG NEXT_PUBLIC_ENABLE_WEBRTC_CALL_UI
ARG NEXT_PUBLIC_MEDIA_PROVIDER_OVERRIDE
ARG NEXT_PUBLIC_VIDEO_WIDTH
ARG NEXT_PUBLIC_VIDEO_HEIGHT
ARG NEXT_PUBLIC_VIDEO_FRAME_RATE
ARG NEXT_PUBLIC_LIVEKIT_ADAPTIVE_STREAM
ARG NEXT_PUBLIC_LIVEKIT_DYNACAST
ARG NEXT_PUBLIC_LIVEKIT_SIMULCAST
ARG NEXT_PUBLIC_LIVEKIT_VIDEO_CODEC
ARG NEXT_PUBLIC_LIVEKIT_VIDEO_MAX_BITRATE

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_LIVEKIT_URL=$NEXT_PUBLIC_LIVEKIT_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_SENTRY_DSN=$NEXT_PUBLIC_SENTRY_DSN
ENV NEXT_PUBLIC_SENTRY_ENVIRONMENT=$NEXT_PUBLIC_SENTRY_ENVIRONMENT
ENV NEXT_PUBLIC_ENABLE_WEBRTC_CALL_UI=$NEXT_PUBLIC_ENABLE_WEBRTC_CALL_UI
ENV NEXT_PUBLIC_MEDIA_PROVIDER_OVERRIDE=$NEXT_PUBLIC_MEDIA_PROVIDER_OVERRIDE
ENV NEXT_PUBLIC_VIDEO_WIDTH=$NEXT_PUBLIC_VIDEO_WIDTH
ENV NEXT_PUBLIC_VIDEO_HEIGHT=$NEXT_PUBLIC_VIDEO_HEIGHT
ENV NEXT_PUBLIC_VIDEO_FRAME_RATE=$NEXT_PUBLIC_VIDEO_FRAME_RATE
ENV NEXT_PUBLIC_LIVEKIT_ADAPTIVE_STREAM=$NEXT_PUBLIC_LIVEKIT_ADAPTIVE_STREAM
ENV NEXT_PUBLIC_LIVEKIT_DYNACAST=$NEXT_PUBLIC_LIVEKIT_DYNACAST
ENV NEXT_PUBLIC_LIVEKIT_SIMULCAST=$NEXT_PUBLIC_LIVEKIT_SIMULCAST
ENV NEXT_PUBLIC_LIVEKIT_VIDEO_CODEC=$NEXT_PUBLIC_LIVEKIT_VIDEO_CODEC
ENV NEXT_PUBLIC_LIVEKIT_VIDEO_MAX_BITRATE=$NEXT_PUBLIC_LIVEKIT_VIDEO_MAX_BITRATE

RUN mkdir -p public && npm run build

FROM node:20-alpine

WORKDIR /app
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
